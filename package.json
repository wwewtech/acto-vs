{
  "name": "acto",
  "displayName": "ACTO_EXT",
  "description": "test",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "acto.parseSelected",
        "title": "ACTO: Парсить выбранные файлы",
        "icon": "$(play-circle)"
      },
      {
        "command": "acto.toggleCheckbox",
        "title": "Toggle Checkbox"
      },
      {
        "command": "acto.selectAll",
        "title": "Выделить все",
        "icon": "$(check-all)"
      },
      {
        "command": "acto.deselectAll",
        "title": "Снять выделение",
        "icon": "$(clear-all)"
      },
      {
        "command": "acto.pauseParsing",
        "title": "Пауза парсинга",
        "icon": "$(debug-pause)"
      },
      {
        "command": "acto.resumeParsing",
        "title": "Продолжить парсинг",
        "icon": "$(debug-continue)"
      },
      {
        "command": "acto.stopParsing",
        "title": "Остановить парсинг",
        "icon": "$(debug-stop)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "acto.parseSelected",
          "when": "view == acto-project-tree",
          "group": "navigation"
        },
        {
          "command": "acto.selectAll",
          "when": "view == acto-project-tree",
          "group": "navigation@1"
        },
        {
          "command": "acto.deselectAll",
          "when": "view == acto-project-tree",
          "group": "navigation@2"
        },
        {
          "command": "acto.pauseParsing",
          "when": "view == acto-project-tree",
          "group": "navigation@3"
        },
        {
          "command": "acto.resumeParsing",
          "when": "view == acto-project-tree",
          "group": "navigation@4"
        },
        {
          "command": "acto.stopParsing",
          "when": "view == acto-project-tree",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "acto.toggleCheckbox",
          "when": "view == acto-project-tree",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "acto-parser-container",
          "title": "ACTO Parser",
          "icon": "$(file-code)"
        }
      ]
    },
    "views": {
      "acto-parser-container": [
        {
          "id": "acto-project-tree",
          "name": "Файлы для парсинга",
          "type": "tree"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "iconv-lite": "^0.6.3"
  },
  "icon": "icon.png",
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.101.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.3",
    "eslint": "^9.25.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3"
  }
}
